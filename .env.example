# ============================================
# SUPABASE (required for photo storage)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_BUCKET=visitor-photos

# ============================================
# MERITTO / NPF CRM
# Leave blank during dev — app gracefully no-ops
# ============================================
MERITTO_API_URL=https://nopaperforms.com/lead/v1/leadCreation
MERITTO_API_KEY=
MERITTO_SOURCE_NAME=NIU Walk-in Kiosk

# Custom field names — pull from your Meritto admin panel
MERITTO_FIELD_PROGRAM=mx_program
MERITTO_FIELD_MEETING_WITH=mx_meeting_with
MERITTO_FIELD_NOTES=mx_notes
MERITTO_FIELD_VISIT_PURPOSE=mx_visit_purpose

# Update / lookup endpoints (Meritto may give different paths)
MERITTO_LOOKUP_URL=https://nopaperforms.com/lead/v1/searchLead
MERITTO_UPDATE_URL=https://nopaperforms.com/lead/v1/updateLead
MERITTO_ACTIVITY_URL=https://nopaperforms.com/lead/v1/addActivity
